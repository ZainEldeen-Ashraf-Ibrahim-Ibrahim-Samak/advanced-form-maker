# ==============================================
# Dynamic Client Data Collection & Admin Review
# ==============================================
# Copy this file to .env.local and fill in your values

# Gemini API (AI Document Auto-Fill)
# GEMINI_API_KEY_2/3/4 are optional fallback keys — if a key hits its quota
# limit, extraction automatically retries with the next configured key.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=submissions

# Pusher (SSE / Live updates)
PUSHER_APP_ID=your-pusher-app-id
PUSHER_KEY=your-pusher-key
PUSHER_SECRET=your-pusher-secret
PUSHER_CLUSTER=eu

# Mobile App & Webview Configuration
MOBILE_APP_BASE_URL=http://localhost:3000
MOBILE_ALLOWED_HOSTS=localhost:3000
APP_ALLOWED_ORIGINS=http://localhost:3000
APP_WEBVIEW_ALLOWED_ORIGINS=http://localhost:3000

# Auth.js (NextAuth v5)
AUTH_URL=http://localhost:3000
AUTH_SECRET=your-auth-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB Connection
MONGODB_URI=mongodb+srv://advanced-form-maker:zawzawzaw@cluster0.mz6emvp.mongodb.net/?appName=Cluster0

# Logging Config
LOG_LEVEL=info
NEXT_PUBLIC_LOG_LEVEL=info

# Vercel Cron
CRON_SECRET=your-vercel-cron-secret

# Google Search Console Verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GOOGLE_HTML_VERIFICATION=
