# ==============================================
# SCCT — Dynamic Client Data Collection & Admin Review
# ==============================================
# Copy this file to .env.local and fill in your values

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/scct?retryWrites=true&w=majority

# Auth.js (NextAuth v5)
AUTH_SECRET=# Generate with: npx auth secret
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron
CRON_SECRET=your-vercel-cron-secret

# Logging (optional)
# Valid values: debug | info | warn | error
LOG_LEVEL=info
NEXT_PUBLIC_LOG_LEVEL=info


# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=scct-submissions

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Gemini API (AI Document Auto-Fill)
GEMINI_API_KEY=your-gemini-api-key

